# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100/
.fseventsd/
.Spotlight-V100/
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

