# ------------------------------------------
# Security & Credentials (CRITICAL)
# ------------------------------------------
# Never commit private keys, passwords, or tokens
*.pem
*.key
*.cert
*.crt
*.pfx
*.p12
*.pub
# Credentials and configuration files
*.env
*.env.local
*.env.*.local
config/jwt/
.git-credentials

